<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Client.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="900"
             d:DesignHeight="620"
             x:Class="Client.LoginView"
             x:DataType="vm:LoginViewModel">

    <UserControl.Styles>
        <Style Selector="TextBox.auth-input">
            <Setter Property="Background" Value="{DynamicResource FieldBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="MinHeight" Value="48"/>
        </Style>

        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style Selector="Button.ghost">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style Selector="Button.eye-toggle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Styles>

    <Border Background="{DynamicResource PageBackgroundBrush}">
        <Grid>
            <Border MaxWidth="420"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    CornerRadius="28"
                    Padding="32"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Авторизация"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Войдите, чтобы продолжить работу с системой мониторинга."
                                   FontSize="14"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,28,0,0" Spacing="8">
                        <TextBlock Text="Логин"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13"/>
                        <TextBox Classes="auth-input"
                                 Watermark="Введите логин"
                                 Text="{Binding Email}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,18,0,0" Spacing="8">
                        <TextBlock Text="Пароль"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13"/>
                        <Grid>
                            <TextBox Classes="auth-input"
                                     Watermark="Введите пароль"
                                     Text="{Binding Password}"
                                     PasswordChar="*"
                                     Padding="16,12,44,12"
                                     IsVisible="{Binding !IsPasswordVisible}"/>
                            <TextBox Classes="auth-input"
                                     Watermark="Введите пароль"
                                     Text="{Binding Password}"
                                     Padding="16,12,44,12"
                                     IsVisible="{Binding IsPasswordVisible}"/>
                            <Button Classes="eye-toggle"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,0,10,0"
                                    Command="{Binding TogglePasswordCommand}">
                                <Panel>
                                    <Path IsVisible="{Binding !IsPasswordVisible}"
                                          Width="20" Height="20" Stretch="Uniform"
                                          Fill="{DynamicResource TextSecondaryBrush}"
                                          Data="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5C21.27 7.61 17 4.5 12 4.5zm0 12.5c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>
                                    <Path IsVisible="{Binding IsPasswordVisible}"
                                          Width="20" Height="20" Stretch="Uniform"
                                          Fill="{DynamicResource TextSecondaryBrush}"
                                          Data="M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.83l2.92 2.92c1.51-1.26 2.7-2.89 3.43-4.75-1.73-4.39-6-7.5-11-7.5-1.4 0-2.74.25-3.98.7l2.16 2.16C10.74 7.13 11.35 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2zm4.31-.78l3.15 3.15.02-.16c0-1.66-1.34-3-3-3l-.17.01z"/>
                                </Panel>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <Border Grid.Row="3"
                            Margin="0,18,0,0"
                            Background="#2A1316"
                            BorderBrush="#5A252B"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12,10"
                            IsVisible="{Binding HasError}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{DynamicResource DangerBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <Button Grid.Row="4"
                            Classes="primary"
                            Margin="0,22,0,0"
                            Content="Войти в систему"
                            Command="{Binding LoginCommand}"
                            IsDefault="True"
                            IsEnabled="{Binding !IsLoading}"/>

                    <StackPanel Grid.Row="5"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Spacing="6"
                                Margin="0,18,0,0">
                        <TextBlock Text="Нет аккаунта?"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <Button Classes="ghost"
                                Content="Зарегистрироваться"
                                Command="{Binding GoToRegisterCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
