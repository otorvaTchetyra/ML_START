<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Client.ViewModels"
             xmlns:media="using:Iciclecreek.Avalonia.Controls.Media"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1200"
             d:DesignHeight="700"
             x:Class="Client.StreamView"
             x:DataType="vm:StreamViewModel">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Настройки"
                      Command="{Binding GoToSettingsCommand}"
                      IsVisible="{Binding IsAdmin}" />
            <MenuItem Header="Видео"
                      Command="{Binding GoToMainCommand}" />
        </Menu>

        <Border DockPanel.Dock="Bottom"
                Background="#1E1E1E"
                Padding="10,5">
            <StackPanel Orientation="Horizontal" Spacing="20">
                <TextBlock Text="{Binding StatusText}"
                           Foreground="Gray"
                           FontSize="12"/>

                <TextBlock Text="{Binding ServerStatus}"
                           Foreground="{Binding ServerStatusColor}"
                           FontSize="12"/>
            </StackPanel>
        </Border>

        <Grid ColumnDefinitions="*,400" Margin="10">
            <Grid Grid.Column="0"
                  RowDefinitions="Auto,*,Auto"
                  Margin="0,0,10,0">
                <TextBlock Grid.Row="0"
                           Text="Видеопоток"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="0,0,0,8"/>

                <Grid Grid.Row="1"
                      Background="Black"
                      VerticalAlignment="Stretch"
                      HorizontalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <ItemsControl ItemsSource="{Binding CurrentFrameInfo.bboxes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas Background="Transparent" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Rectangle Stroke="Red"
                                               StrokeThickness="2"
                                               Fill="Transparent"
                                               Width="{Binding Width}"
                                               Height="{Binding Height}"
                                               Canvas.Left="{Binding x1}"
                                               Canvas.Top="{Binding y1}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Spacing="10"
                                Margin="0,10">
                        <Button Content="Включить стрим"
                                Command="{Binding StartCameraCommand}"/>
                        <Button Content="Остановить стрим"
                                Command="{Binding StopCameraCommand}"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <Grid Grid.Column="1"
                  RowDefinitions="Auto,*,Auto,Auto">
                <TextBlock Grid.Row="0"
                           Text="Журнал событий кормления"
                           FontSize="14"
                           FontWeight="Bold"
                           Margin="0,0,0,8"/>

                <ScrollViewer Grid.Row="1"
                              Margin="0,0,0,10">
                    <ListBox ItemsSource="{Binding Events}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1E1E2E"
                                        CornerRadius="6"
                                        Margin="0,4"
                                        Padding="10">
                                    <StackPanel Spacing="4">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="10">
                                            <TextBlock Text="{Binding Timestamp, StringFormat={}{0:dd.MM.yyyy HH:mm:ss}}"
                                                       FontSize="11"
                                                       Foreground="#888"/>

                                            <Border Background="{Binding StatusColor}"
                                                    CornerRadius="3"
                                                    Padding="4,1">
                                                <TextBlock Text="{Binding IsOutOfSchedule, StringFormat={}Вне расписания}"
                                                           FontSize="10"/>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="15">
                                            <TextBlock Text="{Binding GranuleCount, StringFormat=Гранул: {0}}"
                                                       FontSize="12"/>

                                            <TextBlock Text="{Binding IntensityPerSec, StringFormat=Интенсивность: {0:F1}/сек}"
                                                       FontSize="12"/>
                                        </StackPanel>

                                        <TextBlock Text="{Binding Comment}"
                                                   FontSize="11"
                                                   Foreground="Gray"
                                                   IsVisible="{Binding HasComment}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
