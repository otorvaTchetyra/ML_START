<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Client.ViewModels"
             xmlns:media="using:Iciclecreek.Avalonia.Controls.Media"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Client.StreamView"
             x:DataType="vm:StreamViewModel">
      <DockPanel>

         <!-- Верхнее меню -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Настройки"
                      Command="{Binding GoToSettingsCommand}" />
            <MenuItem Header="Видео"
                      Command="{Binding GoToMainCommand}" />
        </Menu>

        <!-- Статус бар -->
        <Border DockPanel.Dock="Bottom"
                Background="#1E1E1E"
                Padding="10,5">
            <StackPanel Orientation="Horizontal" Spacing="20">
                <TextBlock Text="{Binding StatusText}"
                           Foreground="Gray"
                           FontSize="12"/>

                <TextBlock Text="{Binding ServerStatus}"
                           Foreground="{Binding ServerStatusColor}"
                           FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- Основной контент -->
        <Grid ColumnDefinitions="*,400" Margin="10">

         <!-- Левая часть -->
        <Grid Grid.Column="0"
              RowDefinitions="Auto,*,Auto"
              Margin="0,0,10,0">

            <TextBlock Grid.Row="0"
                       Text="Видеопоток"
                       FontSize="16"
                       FontWeight="Bold"
                       Margin="0,0,0,8"/>
            
            <!-- Видео + кнопки управления = всё в одном Grid -->
            <Grid Grid.Row="1"
                  Background="Black"
                  VerticalAlignment="Stretch"
                  HorizontalAlignment="Stretch">
        
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>     <!-- видео -->
                    <RowDefinition Height="Auto"/>  <!-- кнопки плеера -->
                    <RowDefinition Height="Auto"/>  <!-- кнопки анализа -->
                </Grid.RowDefinitions>
        
                <!-- Видео (растягивается на всю доступную высоту) -->
                <Image Grid.Row="0" Source="{Binding CurrentFrame}" 
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"/>
                
                <!-- Слой для детекций поверх видео -->
                <ItemsControl Grid.Row="0"
                              ItemsSource="{Binding Events}"
                              Background="Transparent">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas Background="Transparent" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Rectangle Stroke="Red" 
                                       StrokeThickness="2"
                                       Fill="Transparent"
                                       Width="50"
                                       Height="50"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                </Grid>
                <!-- Кнопки управления анализом -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            Spacing="10"
                            Margin="0,10">
                    <Button Content="Включить стрим"
                            Command="{Binding StartCameraCommand}"/>
                    <Button Content="Остановить стрим"
                            Command="{Binding StopCameraCommand}"/>
                </StackPanel>
        
    
    
        </Grid>

            <!-- Правая часть -->
            <Grid Grid.Column="1"
                  RowDefinitions="Auto,*,Auto,Auto">

                <!-- Заголовок -->
                <TextBlock Grid.Row="0"
                           Text="Журнал событий кормления"
                           FontSize="14"
                           FontWeight="Bold"
                           Margin="0,0,0,8"/>

                <!-- Список -->
                <ScrollViewer Grid.Row="1"
                              Margin="0,0,0,10">

                    <ListBox ItemsSource="{Binding Events}">

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1E1E2E"
                                        CornerRadius="6"
                                        Margin="0,4"
                                        Padding="10">

                                    <StackPanel Spacing="4">

                                        <!-- Дата + статус -->
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="10">

                                            <TextBlock Text="{Binding Timestamp, StringFormat={}{0:dd.MM.yyyy HH:mm:ss}}"
                                                       FontSize="11"
                                                       Foreground="#888"/>

                                            <Border Background="{Binding StatusColor}"
                                                    CornerRadius="3"
                                                    Padding="4,1">

                                                <TextBlock Text="{Binding IsOutOfSchedule, StringFormat={}Вне расписания}"
                                                           FontSize="10"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- Данные -->
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="15">

                                            <TextBlock Text="{Binding GranuleCount, StringFormat=Гранул: {0}}"
                                                       FontSize="12"/>

                                            <TextBlock Text="{Binding IntensityPerSec, StringFormat=Интенсивность: {0:F1}/сек}"
                                                       FontSize="12"/>
                                        </StackPanel>

                                        <!-- Комментарий -->
                                        <TextBlock Text="{Binding Comment}"
                                                   FontSize="11"
                                                   Foreground="Gray"
                                                   IsVisible="{Binding HasComment}"/>

                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>

                    </ListBox>
                </ScrollViewer>

            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
