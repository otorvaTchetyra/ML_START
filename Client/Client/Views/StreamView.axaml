<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Client.ViewModels"
             xmlns:conv="using:Client.Converters"
             xmlns:media="using:Iciclecreek.Avalonia.Controls.Media"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1200"
             d:DesignHeight="700"
             x:Class="Client.StreamView"
             x:DataType="vm:StreamViewModel">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Настройки"
                      Command="{Binding GoToSettingsCommand}"
                      IsVisible="{Binding IsAdmin}" />
            <MenuItem Header="Видео"
                      Command="{Binding GoToMainCommand}" />
            <MenuItem Header="График"
                      Command="{Binding GoToStatisticsCommand}" />
        </Menu>

        <Border DockPanel.Dock="Bottom"
                Background="#1E1E1E"
                Padding="10,5">
            <StackPanel Orientation="Horizontal" Spacing="20">
                <TextBlock Text="{Binding StatusText}"
                           Foreground="Gray"
                           FontSize="12"/>

                <TextBlock Text="{Binding ServerStatus}"
                           Foreground="{Binding ServerStatusColor}"
                           FontSize="12"/>
            </StackPanel>
        </Border>

        <Grid ColumnDefinitions="*,400" Margin="10">
            <Grid Grid.Column="0"
                  RowDefinitions="Auto,*,Auto"
                  Margin="0,0,10,0">
                <TextBlock Grid.Row="0"
                           Text="Видеопоток"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="0,0,0,8"/>

                <Grid Grid.Row="1"
                      Background="Black"
                      VerticalAlignment="Stretch"
                      HorizontalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Image Source="{Binding CurrentFrame}"
                               Stretch="Uniform"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Stretch"/>
                    </Grid>

                    <StackPanel Grid.Row="1"
                                Orientation="Vertical"
                                Spacing="6"
                                Margin="0,10">

                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="Детекция:"
                                       Foreground="Gray"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0"/>
                            <Button Content="Гранулы"
                                    Width="80"
                                    FontSize="11"
                                    Command="{Binding SetDetectionModeCommand}"
                                    CommandParameter="granule"
                                    Background="{Binding DetectionMode, Converter={x:Static conv:StringEqualColorConverter.Instance}, ConverterParameter=granule}"/>
                            <Button Content="Рыбы"
                                    Width="65"
                                    FontSize="11"
                                    Command="{Binding SetDetectionModeCommand}"
                                    CommandParameter="fish"
                                    Background="{Binding DetectionMode, Converter={x:Static conv:StringEqualColorConverter.Instance}, ConverterParameter=fish}"/>
                            <Button Content="Выкл"
                                    Width="55"
                                    FontSize="11"
                                    Command="{Binding SetDetectionModeCommand}"
                                    CommandParameter="off"
                                    Background="{Binding DetectionMode, Converter={x:Static conv:StringEqualColorConverter.Instance}, ConverterParameter=off}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Канал 1"
                                    Command="{Binding StartChannel1Command}"
                                    Width="90"
                                    Background="{Binding ActiveChannel, Converter={x:Static conv:ChannelColorConverter.Instance}, ConverterParameter=1}"/>
                            <TextBlock Text="youtube.com/watch?v=7i8ARjIeM2k"
                                       Foreground="Gray"
                                       FontSize="11"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Канал 2"
                                    Command="{Binding StartChannel2Command}"
                                    Width="90"
                                    Background="{Binding ActiveChannel, Converter={x:Static conv:ChannelColorConverter.Instance}, ConverterParameter=2}"/>
                            <TextBlock Text="sochi.camera/vse-kamery/cam-40/"
                                       Foreground="Gray"
                                       FontSize="11"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Канал 3"
                                    Command="{Binding StartChannel3Command}"
                                    Width="90"
                                    Background="{Binding ActiveChannel, Converter={x:Static conv:ChannelColorConverter.Instance}, ConverterParameter=3}"/>
                            <TextBox Text="{Binding Channel3Source}"
                                     Watermark="URL или номер камеры"
                                     Width="260"
                                     FontSize="11"/>
                        </StackPanel>

                        <Button Content="Остановить"
                                Command="{Binding StopCameraCommand}"
                                HorizontalAlignment="Left"
                                Width="90"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <Grid Grid.Column="1"
                  RowDefinitions="Auto,*,Auto,Auto">
                <TextBlock Grid.Row="0"
                           Text="Журнал событий кормления"
                           FontSize="14"
                           FontWeight="Bold"
                           Margin="0,0,0,8"/>

                <ScrollViewer Grid.Row="1"
                              Margin="0,0,0,10">
                    <ListBox ItemsSource="{Binding Events}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1E1E2E"
                                        CornerRadius="6"
                                        Margin="0,4"
                                        Padding="10">
                                    <StackPanel Spacing="4">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="10">
                                            <TextBlock Text="{Binding Timestamp, StringFormat={}{0:dd.MM.yyyy HH:mm:ss}}"
                                                       FontSize="11"
                                                       Foreground="#888"/>

                                            <Border Background="{Binding StatusColor}"
                                                    CornerRadius="3"
                                                    Padding="4,1">
                                                <TextBlock Text="{Binding IsOutOfSchedule, StringFormat={}Вне расписания}"
                                                           FontSize="10"/>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="15">
                                            <TextBlock Text="{Binding GranuleCount, StringFormat=Гранул: {0}}"
                                                       FontSize="12"/>

                                            <TextBlock Text="{Binding IntensityPerSec, StringFormat=Интенсивность: {0:F1}/сек}"
                                                       FontSize="12"/>
                                        </StackPanel>

                                        <TextBlock Text="{Binding Comment}"
                                                   FontSize="11"
                                                   Foreground="Gray"
                                                   IsVisible="{Binding HasComment}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
