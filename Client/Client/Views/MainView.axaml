<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Client.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1200"
             d:DesignHeight="700"
             x:Class="Client.MainView"
             x:DataType="vm:MainViewModel">

    <DockPanel>

        <!-- Верхнее меню -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл">
                <MenuItem Header="Открыть видео..."
                          Command="{Binding OpenVideoCommand}" />
            </MenuItem>
            <MenuItem Header="Настройки"
                      Command="{Binding GoToSettingsCommand}" />
        </Menu>

        <!-- Статус бар -->
        <Border DockPanel.Dock="Bottom"
                Background="#1E1E1E"
                Padding="10,5">
            <StackPanel Orientation="Horizontal" Spacing="20">
                <TextBlock Text="{Binding StatusText}"
                           Foreground="Gray"
                           FontSize="12"/>

                <TextBlock Text="{Binding ServerStatus}"
                           Foreground="{Binding ServerStatusColor}"
                           FontSize="12"/>
            </StackPanel>
        </Border>

        <Grid ColumnDefinitions="*,400" Margin="10">

            <!-- Левая часть -->
            <Grid Grid.Column="0"
                  RowDefinitions="Auto,*,Auto"
                  Margin="0,0,10,0">

                <TextBlock Grid.Row="0"
                           Text="Видеопоток"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="0,0,0,8"/>

                <!-- Видео -->
                <Border Grid.Row="1"
                        Background="#111"
                        CornerRadius="6">
                    <TextBlock Text="Видео не загружено"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="Gray"/>
                </Border>

                <!-- Кнопки -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            Spacing="10"
                            Margin="0,10,0,0">

                    <Button Content="Открыть видео"
                            Command="{Binding OpenVideoCommand}"/>

                    <Button Content="Остановить анализ"
                            Command="{Binding StopStreamCommand}"/>

                    <Button Content="Обновить данные"
                            Command="{Binding RefreshCommand}"/>
                </StackPanel>
            </Grid>

            <!-- Правая часть -->
            <Grid Grid.Column="1"
                  RowDefinitions="Auto,*,Auto,*">

                <!-- Заголовок -->
                <TextBlock Grid.Row="0"
                           Text="Журнал событий кормления"
                           FontSize="14"
                           FontWeight="Bold"
                           Margin="0,0,0,8"/>

                <!-- Список -->
                <ScrollViewer Grid.Row="1"
                              Margin="0,0,0,10">

                    <ListBox ItemsSource="{Binding Events}"
                             SelectedItem="{Binding SelectedEvent}">

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1E1E2E"
                                        CornerRadius="6"
                                        Margin="0,4"
                                        Padding="10">

                                    <StackPanel Spacing="4">

                                        <!-- Дата + статус -->
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="10">

                                            <!-- ✅ исправлено -->
                                            <TextBlock Text="{Binding Timestamp, StringFormat={}{0:dd.MM.yyyy HH:mm:ss}}"
                                                       FontSize="11"
                                                       Foreground="#888"/>

                                            <Border Background="{Binding StatusColor}"
                                                    CornerRadius="3"
                                                    Padding="4,1">

                                                <!-- ✅ тоже поправлено -->
                                                <TextBlock Text="{Binding IsOutOfSchedule, StringFormat={}Вне расписания}"
                                                           FontSize="10"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- Данные -->
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="15">

                                            <TextBlock Text="{Binding GranuleCount, StringFormat=Гранул: {0}}"
                                                       FontSize="12"/>

                                            <TextBlock Text="{Binding IntensityPerSec, StringFormat=Интенсивность: {0:F1}/сек}"
                                                       FontSize="12"/>
                                        </StackPanel>

                                        <!-- Комментарий -->
                                        <TextBlock Text="{Binding Comment}"
                                                   FontSize="11"
                                                   Foreground="Gray"
                                                   IsVisible="{Binding HasComment}"/>

                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>

                    </ListBox>
                </ScrollViewer>

                <!-- Комментарий -->
                <TextBlock Grid.Row="2"
                           Text="Комментарий к событию"
                           FontSize="14"
                           FontWeight="Bold"
                           Margin="0,0,0,8"/>

                <Grid Grid.Row="3"
                      RowDefinitions="*,Auto">

                    <TextBox Grid.Row="0"
                             Text="{Binding CommentText}"
                             Watermark="Введите комментарий..."
                             AcceptsReturn="True"
                             Margin="0,0,0,8"/>

                    <Button Grid.Row="1"
                            Content="Добавить комментарий"
                            Command="{Binding AddCommentCommand}"
                            IsEnabled="{Binding SelectedEvent, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                </Grid>

            </Grid>
        </Grid>
    </DockPanel>
</UserControl>