<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Client.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="960"
             d:DesignHeight="720"
             x:Class="Client.AdminHomeView"
             x:DataType="vm:AdminHomeViewModel">

    <UserControl.Styles>
        <Style Selector="Button.nav-tile">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Padding" Value="28,24"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.nav-tile:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource FieldBrush}"/>
        </Style>
        <Style Selector="Button.ghost">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>
    </UserControl.Styles>

    <Border Background="{DynamicResource PageBackgroundBrush}">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32" Spacing="28" MaxWidth="920" HorizontalAlignment="Center">

                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{Binding WelcomeText}"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Выберите раздел. Системные параметры сервера и модели — в «Настройках»."
                                   FontSize="14"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Top">
                        <Button Classes="ghost" Content="Выйти" Command="{Binding LogoutCommand}"/>
                    </StackPanel>
                </Grid>

                <UniformGrid Columns="2" Rows="2" MinHeight="280">
                    <Button Classes="nav-tile"
                            Margin="0,0,12,12"
                            Command="{Binding GoToUsersCommand}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Учётные записи"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Создание и удаление операторов (доступ к анализу видео)."
                                       FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="nav-tile"
                            Margin="12,0,0,12"
                            Command="{Binding GoToJournalCommand}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Журнал пользователей"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Локальный журнал клиента с фильтром по логину."
                                       FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="nav-tile"
                            Margin="0,12,12,0"
                            Command="{Binding GoToSettingsCommand}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Настройки системы"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="URL сервера, тема, пороги модели."
                                       FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="nav-tile"
                            Margin="12,12,0,0"
                            Command="{Binding GoToVideoCommand}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Панель мониторинга"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Анализ записанного видео и журнал событий."
                                       FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Button>
                </UniformGrid>

                <Button Classes="ghost"
                        HorizontalAlignment="Center"
                        Content="Открыть видеострим"
                        Command="{Binding GoToStreamCommand}"/>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
