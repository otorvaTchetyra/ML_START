<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Client.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="960"
             d:DesignHeight="780"
             x:Class="Client.AdminUsersView"
             x:DataType="vm:AdminUsersViewModel">

    <UserControl.Styles>
        <Style Selector="TextBox.auth-input">
            <Setter Property="Background" Value="{DynamicResource FieldBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="MinHeight" Value="48"/>
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="{DynamicResource FieldBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>
        <Style Selector="Button.ghost">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="Button.eye-toggle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Styles>

    <Border Background="{DynamicResource PageBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="24" RowDefinitions="Auto,*">
                <Button Grid.Row="0"
                        Classes="ghost"
                        HorizontalAlignment="Left"
                        Content="← Назад в панель"
                        Command="{Binding BackCommand}"
                        Margin="0,0,0,12"/>

                <Border Grid.Row="1"
                        MaxWidth="560"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        CornerRadius="28"
                        Padding="32"
                        Background="{DynamicResource PanelBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="18">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Учётные записи"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Операторы входят под своим логином и работают с анализом видео. Учётная запись admin одна."
                                       FontSize="14"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Classes="secondary"
                                    Content="Обновить список"
                                    Command="{Binding RefreshCommand}"/>
                        </StackPanel>

                        <ListBox MinHeight="140"
                                 MaxHeight="220"
                                 ItemsSource="{Binding ServerUsers}"
                                 SelectedItem="{Binding SelectedServerUser, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="1"
                                 BorderBrush="{DynamicResource BorderBrush}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*,Auto" Margin="0,6">
                                        <TextBlock Text="{Binding Username}"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Grid.Column="1"
                                                   Margin="12,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="12"
                                                   Text="{Binding Role}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Classes="secondary"
                                    Content="Удалить выбранного"
                                    Command="{Binding DeleteUserCommand}"/>
                        </StackPanel>

                        <Border IsVisible="{Binding IsEditVisible}"
                                Background="{DynamicResource FieldBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Редактировать пользователя"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBox Classes="auth-input"
                                         Watermark="Логин"
                                         Text="{Binding EditUsername, Mode=TwoWay}"/>
                                <Grid>
                                    <TextBox Classes="auth-input"
                                             PasswordChar="*"
                                             Watermark="Новый пароль (оставьте пустым, чтобы не менять)"
                                             Padding="16,12,44,12"
                                             Text="{Binding EditPassword, Mode=TwoWay}"
                                             IsVisible="{Binding !IsEditPasswordVisible}"/>
                                    <TextBox Classes="auth-input"
                                             Watermark="Новый пароль (оставьте пустым, чтобы не менять)"
                                             Padding="16,12,44,12"
                                             Text="{Binding EditPassword, Mode=TwoWay}"
                                             IsVisible="{Binding IsEditPasswordVisible}"/>
                                    <Button Classes="eye-toggle"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Margin="0,0,10,0"
                                            Command="{Binding ToggleEditPasswordCommand}">
                                        <Panel>
                                            <Path IsVisible="{Binding !IsEditPasswordVisible}"
                                                  Width="20" Height="20" Stretch="Uniform"
                                                  Fill="{DynamicResource TextSecondaryBrush}"
                                                  Data="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5C21.27 7.61 17 4.5 12 4.5zm0 12.5c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>
                                            <Path IsVisible="{Binding IsEditPasswordVisible}"
                                                  Width="20" Height="20" Stretch="Uniform"
                                                  Fill="{DynamicResource TextSecondaryBrush}"
                                                  Data="M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.83l2.92 2.92c1.51-1.26 2.7-2.89 3.43-4.75-1.73-4.39-6-7.5-11-7.5-1.4 0-2.74.25-3.98.7l2.16 2.16C10.74 7.13 11.35 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2zm4.31-.78l3.15 3.15.02-.16c0-1.66-1.34-3-3-3l-.17.01z"/>
                                        </Panel>
                                    </Button>
                                </Grid>
                                <ComboBox ItemsSource="{Binding AvailableRoles}"
                                          SelectedItem="{Binding EditRole, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch"/>
                                <Button Classes="primary"
                                        Content="Сохранить изменения"
                                        Command="{Binding SaveEditCommand}"
                                        IsEnabled="{Binding !IsBusy}"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Separator/>

                        <TextBlock Text="Новый оператор"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBox Classes="auth-input"
                                 Watermark="Логин"
                                 Text="{Binding NewOperatorUsername, Mode=TwoWay}"/>
                        <Grid>
                            <TextBox Classes="auth-input"
                                     PasswordChar="*"
                                     Watermark="Пароль"
                                     Padding="16,12,44,12"
                                     Text="{Binding NewOperatorPassword, Mode=TwoWay}"
                                     IsVisible="{Binding !IsNewPasswordVisible}"/>
                            <TextBox Classes="auth-input"
                                     Watermark="Пароль"
                                     Padding="16,12,44,12"
                                     Text="{Binding NewOperatorPassword, Mode=TwoWay}"
                                     IsVisible="{Binding IsNewPasswordVisible}"/>
                            <Button Classes="eye-toggle"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,0,10,0"
                                    Command="{Binding ToggleNewPasswordCommand}">
                                <Panel>
                                    <Path IsVisible="{Binding !IsNewPasswordVisible}"
                                          Width="20" Height="20" Stretch="Uniform"
                                          Fill="{DynamicResource TextSecondaryBrush}"
                                          Data="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5C21.27 7.61 17 4.5 12 4.5zm0 12.5c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>
                                    <Path IsVisible="{Binding IsNewPasswordVisible}"
                                          Width="20" Height="20" Stretch="Uniform"
                                          Fill="{DynamicResource TextSecondaryBrush}"
                                          Data="M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.83l2.92 2.92c1.51-1.26 2.7-2.89 3.43-4.75-1.73-4.39-6-7.5-11-7.5-1.4 0-2.74.25-3.98.7l2.16 2.16C10.74 7.13 11.35 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2zm4.31-.78l3.15 3.15.02-.16c0-1.66-1.34-3-3-3l-.17.01z"/>
                                </Panel>
                            </Button>
                        </Grid>

                        <Button Classes="primary"
                                Content="Создать пользователя"
                                Command="{Binding CreateOperatorCommand}"
                                IsEnabled="{Binding !IsBusy}"
                                IsDefault="True"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"/>

                        <Border Background="#152A18"
                                BorderBrush="#2A5A32"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12,10"
                                IsVisible="{Binding HasFeedback}">
                            <TextBlock Text="{Binding FeedbackMessage}"
                                       Foreground="{Binding FeedbackBrush}"
                                       FontSize="13"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Border>
</UserControl>
