<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Client.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="960"
             d:DesignHeight="780"
             x:Class="Client.AdminUsersView"
             x:DataType="vm:AdminUsersViewModel">

    <UserControl.Styles>
        <Style Selector="TextBox.auth-input">
            <Setter Property="Background" Value="{DynamicResource FieldBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="MinHeight" Value="48"/>
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="{DynamicResource FieldBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>
        <Style Selector="Button.ghost">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </UserControl.Styles>

    <Border Background="{DynamicResource PageBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="24" RowDefinitions="Auto,*">
                <Button Grid.Row="0"
                        Classes="ghost"
                        HorizontalAlignment="Left"
                        Content="← Назад в панель"
                        Command="{Binding BackCommand}"
                        Margin="0,0,0,12"/>

                <Border Grid.Row="1"
                        MaxWidth="560"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        CornerRadius="28"
                        Padding="32"
                        Background="{DynamicResource PanelBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="18">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Учётные записи"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Операторы входят под своим логином и работают с анализом видео. Учётная запись admin одна."
                                       FontSize="14"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Classes="secondary"
                                    Content="Обновить список"
                                    Command="{Binding RefreshCommand}"/>
                        </StackPanel>

                        <ListBox MinHeight="140"
                                 MaxHeight="220"
                                 ItemsSource="{Binding ServerUsers}"
                                 SelectedItem="{Binding SelectedServerUser, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="1"
                                 BorderBrush="{DynamicResource BorderBrush}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*,Auto" Margin="0,6">
                                        <TextBlock Text="{Binding Username}"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Grid.Column="1"
                                                   Margin="12,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="12"
                                                   Text="{Binding Role}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Classes="secondary"
                                    Content="Удалить выбранного"
                                    Command="{Binding DeleteUserCommand}"/>
                        </StackPanel>

                        <Border IsVisible="{Binding IsEditVisible}"
                                Background="{DynamicResource FieldBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Редактировать пользователя"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBox Classes="auth-input"
                                         Watermark="Логин"
                                         Text="{Binding EditUsername, Mode=TwoWay}"/>
                                <TextBox Classes="auth-input"
                                         PasswordChar="*"
                                         Watermark="Новый пароль (оставьте пустым, чтобы не менять)"
                                         Text="{Binding EditPassword, Mode=TwoWay}"/>
                                <ComboBox ItemsSource="{Binding AvailableRoles}"
                                          SelectedItem="{Binding EditRole, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch"/>
                                <Button Classes="primary"
                                        Content="Сохранить изменения"
                                        Command="{Binding SaveEditCommand}"
                                        IsEnabled="{Binding !IsBusy}"/>
                            </StackPanel>
                        </Border>

                        <Separator/>

                        <TextBlock Text="Новый оператор"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBox Classes="auth-input"
                                 Watermark="Логин"
                                 Text="{Binding NewOperatorUsername, Mode=TwoWay}"/>
                        <TextBox Classes="auth-input"
                                 PasswordChar="*"
                                 Watermark="Пароль"
                                 Text="{Binding NewOperatorPassword, Mode=TwoWay}"/>

                        <Button Classes="primary"
                                Content="Создать пользователя"
                                Command="{Binding CreateOperatorCommand}"
                                IsEnabled="{Binding !IsBusy}"/>

                        <Border Background="#152A18"
                                BorderBrush="#2A5A32"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12,10"
                                IsVisible="{Binding HasFeedback}">
                            <TextBlock Text="{Binding FeedbackMessage}"
                                       Foreground="{Binding FeedbackBrush}"
                                       FontSize="13"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Border>
</UserControl>
