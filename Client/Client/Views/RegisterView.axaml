<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Client.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="900"
             d:DesignHeight="680"
             x:Class="Client.RegisterView"
             x:DataType="vm:RegisterViewModel">

    <UserControl.Styles>
        <Style Selector="TextBox.auth-input">
            <Setter Property="Background" Value="{DynamicResource FieldBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="MinHeight" Value="48"/>
        </Style>

        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <Style Selector="Button.ghost">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </UserControl.Styles>

    <Border Background="{DynamicResource PageBackgroundBrush}">
        <Grid>
            <Border MaxWidth="440"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    CornerRadius="28"
                    Padding="32"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Регистрация"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Создайте учётную запись, чтобы получить доступ к панели мониторинга."
                                   FontSize="14"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,28,0,0" Spacing="8">
                        <TextBlock Text="Email"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13"/>
                        <TextBox Classes="auth-input"
                                 Watermark="Введите email"
                                 Text="{Binding Email}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,18,0,0" Spacing="8">
                        <TextBlock Text="Пароль"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13"/>
                        <TextBox Classes="auth-input"
                                 Watermark="Введите пароль"
                                 Text="{Binding Password}"
                                 PasswordChar="*"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,18,0,0" Spacing="8">
                        <TextBlock Text="Подтверждение пароля"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13"/>
                        <TextBox Classes="auth-input"
                                 Watermark="Повторите пароль"
                                 Text="{Binding ConfirmPassword}"
                                 PasswordChar="*"/>
                    </StackPanel>

                    <Border Grid.Row="4"
                            Margin="0,18,0,0"
                            Background="#2A1316"
                            BorderBrush="#5A252B"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12,10"
                            IsVisible="{Binding HasError}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{DynamicResource DangerBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <Button Grid.Row="5"
                            Classes="primary"
                            Margin="0,22,0,0"
                            Content="Создать аккаунт"
                            Command="{Binding RegisterCommand}"
                            IsEnabled="{Binding !IsLoading}"/>

                    <StackPanel Grid.Row="6"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Spacing="6"
                                Margin="0,18,0,0">
                        <TextBlock Text="Уже есть аккаунт?"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <Button Classes="ghost"
                                Content="Войти"
                                Command="{Binding GoToLoginCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
