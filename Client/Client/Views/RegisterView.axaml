<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Client.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="using:Client.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Client.RegisterView"
             x:DataType="vm:RegisterViewModel">
  <Grid RowDefinitions="Auto,*,Auto" Margin="20">
        
        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="Регистрация"
                   FontSize="20"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>
        
        <!-- Поля ввода -->
        <StackPanel Grid.Row="1" Spacing="12">
            
            <!-- Email -->
            <TextBox Watermark="Email" 
                     Text="{Binding Email}"/>
            
            <!-- Пароль -->
            <TextBox Watermark="Пароль"
                     Text="{Binding Password}"
                     PasswordChar="●"/>
            
            <!-- Подтверждение пароля -->
            <TextBox Watermark="Подтвердите пароль"
                     Text="{Binding ConfirmPassword}"
                     PasswordChar="●"/>
            
            <!-- Ошибка -->
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="Red"
                       FontSize="12"
                       IsVisible="{Binding !IsLoading}"
                       TextWrapping="Wrap"/>
            
            <!-- Кнопка регистрации -->
            <Button Content="Зарегистрироваться"
                    Command="{Binding RegisterCommand}"
                    IsEnabled="{Binding !IsLoading}"
                    HorizontalAlignment="Stretch"
                    Padding="10"
                    Margin="0,10,0,0"/>
        </StackPanel>
        
        <!-- Ссылка на вход -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="5"
                    Margin="0,15,0,0">
            <TextBlock Text="Уже есть аккаунт?" Foreground="Gray"/>
            <Button Content="Войти"
                    Command="{Binding GoToLoginCommand}"
                    Classes="link"
                    Padding="0"/>
        </StackPanel>
        
    </Grid>
</UserControl>
