<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Client.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Client.SettingsView"
             x:DataType="vm:SettingsViewModel">
  <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" Margin="20" RowSpacing="15">
        
        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="⚙️ Настройки приложения"
                   FontSize="18"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>
        
        <!-- 1. Настройки подключения к серверу -->
        <Border Grid.Row="1"
                BorderBrush="#DDD"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="🔌 Подключение к серверу"
                           FontWeight="Bold"
                           FontSize="14"/>
                
                <TextBox Watermark="URL сервера (например, http://localhost:8000)"
                         Text="{Binding UrlServerPath, Mode=TwoWay}"
                         Margin="0,5,0,0"/>
                
                <Button Content="Проверить подключение"
                        Command="{Binding TestConnectionCommand}"
                        HorizontalAlignment="Left"
                        Padding="15,5"
                        Margin="0,8,0,0"/>
                
                <TextBlock Text="{Binding ConnectionStatus}"
                           FontSize="12"
                           IsVisible="{Binding !IsTestingConnection}"/>
            </StackPanel>
        </Border>
        
        <!-- 2. Настройки нейросети -->
        <Border Grid.Row="2"
                BorderBrush="#DDD"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="🧠 Параметры нейросети"
                           FontWeight="Bold"
                           FontSize="14"/>
                
                <!-- Confidence -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                    <TextBlock Grid.Column="0" 
                               Text="Порог уверенности (Confidence):"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" 
                               Text="{Binding Confidence, StringFormat=F2}"
                               Width="45"
                               TextAlignment="Center"/>
                </Grid>
                <Slider Minimum="0" 
                        Maximum="1" 
                        Value="{Binding Confidence}"
                        Margin="0,0,0,8"/>
                
                <!-- IoU -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                    <TextBlock Grid.Column="0" 
                               Text="Порог пересечения (IoU):"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" 
                               Text="{Binding Iou, StringFormat=F2}"
                               Width="45"
                               TextAlignment="Center"/>
                </Grid>
                <Slider Minimum="0" 
                        Maximum="1" 
                        Value="{Binding Iou}"/>
                
               
            </StackPanel>
        </Border>
        
        <!-- 3. Кнопки действий -->
        <StackPanel Grid.Row="3" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Spacing="10"
                    Margin="0,15,0,0">
            <Button Content="Сохранить"
                    Command="{Binding SaveSettingsCommand}"
                    Classes="primary"
                    Padding="20,8"/>
        </StackPanel>
        
        <!-- Сообщение о статусе -->
        <TextBlock Grid.Row="4" 
                   Text="{Binding StatusMessage}"
                   Foreground="{Binding StatusMessageColor}"
                   FontSize="12"
                   TextAlignment="Center"
                   IsVisible="{Binding IsStatusVisible}"
                   Margin="0,10,0,0"/>
        
    </Grid>
</UserControl>
